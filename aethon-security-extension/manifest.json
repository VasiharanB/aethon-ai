{
  "manifest_version": 3,
  "name": "Aethon Exam Security Shield",
  "version": "1.0",
  "description": "Proctoring extension to ensure exam integrity and detect active focus bypasses.",
  "permissions": [
    "management"
  ],
  "host_permissions": [
    "*://localhost/*",
    "*://127.0.0.1/*",
    "*://*.aethon.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://localhost/*", "*://127.0.0.1/*", "*://*.aethon.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
